# Tether WDK Indexer API key
# Get your API key at: https://docs.wdk.tether.io/tools/indexer-api/get-started
EXPO_PUBLIC_WDK_INDEXER_API_KEY=your_api_key_here

# Optional: Custom indexer URL (default: https://wdk-api.tether.io)
EXPO_PUBLIC_WDK_INDEXER_BASE_URL=https://wdk-api.tether.io

# Optional: Local proxy for WDK API when app gets ERR_NETWORK (e.g. run node wdk-proxy-server.js, use your machine's LAN IP)
# EXPO_PUBLIC_WDK_PROXY_URL=http://192.168.1.100:3000
